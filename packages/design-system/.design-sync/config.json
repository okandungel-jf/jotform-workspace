    "SearchInput": "src/components/SearchInput/SearchInput.tsx",
    "DateInput": "src/components/DateInput/DateInput.tsx",
    "DropdownSingle": "src/components/Dropdown/DropdownSingle.tsx",
    "DropdownMulti": "src/components/Dropdown/DropdownMulti.tsx",
    "DropdownLanguage": "src/components/Dropdown/DropdownLanguage.tsx",
    "DropdownMenuShell": "src/components/Dropdown/DropdownMenuShell.tsx",
    "Toggle": "src/components/Toggle/Toggle.tsx",
    "Slider": "src/components/Slider/Slider.tsx",
    "Input": "src/components/Input/Input.tsx",
    "TextArea": "src/components/TextArea/TextArea.tsx",
    "ColorInput": "src/components/ColorInput/ColorInput.tsx",
    "UrlInput": "src/components/UrlInput/UrlInput.tsx",
    "FieldChip": "src/components/FieldChip/FieldChip.tsx",
    "FieldMapper": "src/components/FieldMapper/FieldMapper.tsx",
    "FieldComposer": "src/components/FieldComposer/FieldComposer.tsx",
    "FormField": "src/components/FormField/FormField.tsx",
    "NumberInput": "src/components/NumberInput/NumberInput.tsx",
    "Modal": "src/components/Modal/Modal.tsx",
    "Link": "src/components/Link/Link.tsx",
    "Badge": "src/components/Badge/Badge.tsx",
    "Indicator": "src/components/Indicator/Indicator.tsx",
    "Dialog": "src/components/Dialog/Dialog.tsx",
    "Tabs": "src/components/Tabs/Tabs.tsx",
    "Segmented": "src/components/Segmented/Segmented.tsx",
    "Checkbox": "src/components/Checkbox/Checkbox.tsx",
    "RadioButton": "src/components/RadioButton/RadioButton.tsx",
    "Header": "src/components/Header/Header.tsx",
    "Table": "src/components/Table/Table.tsx",
    "TableTitle": "src/components/Table/TableTitle.tsx",
    "DesignLibrary": null
  }
}
