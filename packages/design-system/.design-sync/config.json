{
  "pkg": "@jf/design-system",
  "globalName": "JFDesignSystem",
  "projectId": "b403d5e9-65b9-433c-97e5-84dcb70e710c",
  "shape": "package",
  "buildCmd": "node .design-sync/extract-host-tokens.mjs && npx vite build -c .design-sync/vite.lib.config.mts && npx tsc -p .design-sync/tsconfig.dts.json",
